.community-post-page {
  width: 100%;
  height: calc(100vh - 240rpx - env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
}

.community-scroll {
  flex: 1;
  overflow: hidden;
}

.section {
  background: #2d2d2d;
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
  display: block;
}

.optional-hint {
  font-size: 24rpx;
  font-weight: 400;
  color: #888888;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  padding: 16rpx 36rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #888888;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.category-item.selected {
  background: rgba(0, 212, 255, 0.15);
  border-color: #00d4ff;
  color: #00d4ff;
}

.category-item:active {
  opacity: 0.7;
}

.campus-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.campus-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.campus-university-name {
  font-size: 26rpx;
  color: #888888;
  font-weight: 500;
}

.campus-items {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.campus-item {
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #888888;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.campus-item.selected {
  background: rgba(0, 212, 255, 0.15);
  border-color: #00d4ff;
  color: #00d4ff;
}

.campus-empty {
  padding: 20rpx;
  text-align: center;
  color: #666666;
  font-size: 26rpx;
}

.title-input {
  box-sizing: border-box;
  height: 70rpx;
  width: 100%;
  padding: 8rpx 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
}

.title-input:focus {
  border-color: #00d4ff;
}

.title-input::placeholder {
  color: #888888;
}

.content-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  line-height: 1.6;
}

.content-input:focus {
  border-color: #00d4ff;
}

.content-input::placeholder {
  color: #888888;
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.media-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #1a1a1a;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.media-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-preview {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
}

.video-play-icon {
  position: absolute;
  color: #fff;
  font-size: 48rpx;
}

.media-item.uploaded {
  border-color: rgba(0, 212, 255, 0.4);
}

.media-item.upload-error {
  border-color: rgba(255, 71, 87, 0.6);
}

.upload-status {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.6);
}

.status-icon {
  font-size: 24rpx;
}

.status-icon.success {
  color: #00d4ff;
}

.status-icon.error {
  color: #ff4757;
}

.status-icon.uploading {
  color: #fbbf24;
}

.media-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(255, 71, 87, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.media-add {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(255, 255, 255, 0.2);
}

.media-add:active {
  border-color: #00d4ff;
}

.media-add-icon {
  font-size: 60rpx;
  color: #888888;
}

.bottom-spacer {
  height: 140rpx;
}

.submit-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: #2d2d2d;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 212, 255, 0.4);
}

.submit-btn.disabled {
  background: #666666;
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}
