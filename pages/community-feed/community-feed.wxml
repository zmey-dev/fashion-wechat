<wxs src="../../utils/userDisplayName.wxs" module="userUtils" />
<app-layout current-page="{{layoutCurrentPage}}" bind:search="onSearch">
  <scroll-view
    class="feed-scroll"
    scroll-y="{{true}}"
    bindscrolltolower="onReachBottom"
    lower-threshold="100"
  >
    <view class="feed-list">
      <view
        wx:for="{{posts}}"
        wx:key="id"
        class="feed-card"
        data-post-id="{{item.id}}"
        data-index="{{index}}"
        bindtap="onPostTap"
      >
        <view class="feed-card-header">
          <view class="feed-user" catchtap="onUserTap" data-username="{{item.user.username}}" data-user-id="{{item.user.id}}">
            <avatar avatar="{{item.user.avatar}}" user="{{item.user}}" size="70"></avatar>
            <text class="feed-username">{{userUtils.getShortDisplayName(item.user, 10)}}</text>
          </view>
          <text class="feed-time">{{item.time_display}}</text>
        </view>

        <view class="feed-card-body">
          <text class="feed-text">{{item.content}}</text>
          <view class="feed-media" wx:if="{{item.media && item.media.length > 0}}">
            <image
              wx:if="{{item.type === 'video'}}"
              class="feed-image {{item.media.length === 1 ? 'single' : ''}}"
              src="{{item.media[0].preview_url}}"
              mode="aspectFill"
              lazy-load="{{true}}"
            />
            <block wx:else>
              <image
                wx:for="{{item.media}}"
                wx:for-item="media"
                wx:for-index="mIdx"
                wx:key="id"
                wx:if="{{mIdx < 3}}"
                class="feed-image {{item.media.length === 1 ? 'single' : item.media.length === 2 ? 'double' : 'triple'}}"
                src="{{media.url}}"
                mode="aspectFill"
                lazy-load="{{true}}"
              />
            </block>
            <view class="feed-media-more" wx:if="{{item.media.length > 3}}">
              <text>+{{item.media.length - 3}}</text>
            </view>
          </view>
        </view>

        <view class="feed-card-footer">
          <view class="feed-tags">
            <view class="feed-tag category-tag" wx:if="{{item.category}}">
              <text class="tag-icon">#</text>
              <text>{{item.category}}</text>
            </view>
            <view class="feed-tag campus-tag" wx:if="{{item.campus}}">
              <text class="tag-icon">◉</text>
              <text>{{item.campus.name}}</text>
            </view>
          </view>
          <view class="feed-actions">
            <view class="feed-action">
              <image class="action-icon" src="/images/icons/heart.svg" mode="aspectFit" />
              <text class="action-count">{{item.likes || 0}}</text>
            </view>
            <view class="feed-action">
              <image class="action-icon" src="/images/icons/message.svg" mode="aspectFit" />
              <text class="action-count">{{item.comments || 0}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loadingMore}}">
      <text>加载中...</text>
    </view>

    <view class="empty-state" wx:if="{{!loading && posts.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-title">还没有内容</text>
      <text class="empty-desc">快来发布第一条动态吧</text>
    </view>

    <view class="end-message" wx:if="{{!hasMore && posts.length > 0}}">
      <text>— 已经到底了 —</text>
    </view>
  </scroll-view>
</app-layout>
