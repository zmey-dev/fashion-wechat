.feed-scroll {
  height: calc(100vh - 200rpx);
}

.feed-list {
  padding: 0 24rpx;
}

.feed-card {
  background: #1a1a1a;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.feed-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.feed-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.feed-username {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.feed-time {
  font-size: 24rpx;
  color: #666666;
}

.feed-card-body {
  margin-bottom: 20rpx;
}

.feed-text {
  font-size: 30rpx;
  color: #e0e0e0;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

.feed-media {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
  position: relative;
}

.feed-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #2d2d2d;
}

.feed-media-more {
  width: 140rpx;
  height: 140rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.feed-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.feed-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  flex: 1;
}

.feed-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.category-tag {
  background: rgba(255, 255, 255, 0.08);
  color: #aaaaaa;
}

.campus-tag {
  background: rgba(255, 255, 255, 0.08);
  color: #aaaaaa;
}

.tag-icon {
  font-size: 20rpx;
  color: #888888;
}

.feed-actions {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.feed-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.action-count {
  font-size: 24rpx;
  color: #888888;
}

.loading-more {
  padding: 30rpx;
  text-align: center;
  color: #666666;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #666666;
}

.end-message {
  padding: 30rpx;
  text-align: center;
  color: #444444;
  font-size: 24rpx;
}
