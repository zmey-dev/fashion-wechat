/* components/post-info-overlay/post-info-overlay.wxss */

/* Post Info Container */
.post-info {
  position: absolute;
  z-index: 300;
  pointer-events: none;
}

/* Collapsed state - small icon at bottom-left */
.post-info.collapsed {
  bottom: 0rpx;
  left: 24rpx;
}

/* Expanded state - panel at bottom-left */
.post-info.expanded {
  bottom: 24rpx;
  left: 24rpx;
  right: 160rpx;
  max-width: calc(100vw - 200rpx);
}

/* Horizontal mode adjustments */
.post-info.horizontal-mode.collapsed {
  left: 48rpx;
}

.post-info.horizontal-mode.expanded {
  left: 48rpx;
  max-width: calc(100vh - 200rpx);
}

/* Collapse Icon Button */
.collapse-icon-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  pointer-events: auto;
  transition: all 0.2s ease;
}

.collapse-icon-btn:active {
  background: rgba(0, 0, 0, 0.7);
  transform: scale(0.95);
}

.collapse-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}


/* Expanded Content Container */
.expanded-content {
  background: rgba(0, 0, 0, 0.75);
  border-radius: 16rpx;
  padding: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  pointer-events: auto;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Expanded Header */
.expanded-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

/* Post Title */
.post-title {
  flex: 1;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Collapse Button */
.collapse-btn {
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.collapse-btn:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.collapse-btn-icon {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

/* Post Content Scroll */
.post-content-scroll {
  max-height: 40vh;
}

.post-content-native-scroll {
  max-height: 30vw;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* Post Content Text */
.post-content-expanded {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-word;
  display: block;
}

/* Custom scrollbar */
.post-content-scroll::-webkit-scrollbar {
  width: 6rpx;
}

.post-content-scroll::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3rpx;
}

.post-content-scroll::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 3rpx;
}

.post-content-scroll::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.5);
}
