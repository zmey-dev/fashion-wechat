<!-- components/post-info-overlay/post-info-overlay.wxml -->
<view class="post-info {{ isExpanded ? 'expanded' : 'collapsed' }} {{ orientation === 'horizontal' ? 'horizontal-mode' : '' }}">
  <!-- Collapsed state: Only show expand icon -->
  <view
    wx:if="{{ !isExpanded }}"
    class="collapse-icon-btn"
    catchtap="toggleExpand"
  >
    <image
      src="/images/icons/chevron-up.svg"
      class="collapse-icon"
      mode="aspectFit"
    />
  </view>

  <!-- Expanded state: Show full info content -->
  <view wx:if="{{ isExpanded }}" class="expanded-content">
    <view class="expanded-header">
      <view class="post-title">{{ displayTitle }}</view>
      <view class="collapse-btn" catchtap="toggleExpand">
        <image
          src="/images/icons/chevron-down.svg"
          class="collapse-btn-icon"
          mode="aspectFit"
        />
      </view>
    </view>

    <scroll-view
      wx:if="{{ displayContent && orientation === 'vertical' }}"
      class="post-content-scroll"
      scroll-y="true"
      enhanced="true"
      show-scrollbar="true"
      bounces="true"
    >
      <view class="post-content-expanded">{{ fullContent }}</view>
    </scroll-view>
    <view
      wx:if="{{ displayContent && orientation === 'horizontal' }}"
      class="post-content-native-scroll"
    >
      <view class="post-content-expanded">{{ fullContent }}</view>
    </view>
  </view>
</view>